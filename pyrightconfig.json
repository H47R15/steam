// Local pyright config for the steam package.  Anchors the project root at
// this directory so ``stubPath`` (and ``include`` / ``exclude``) resolve
// relative to the repo root — without this file pyright walks up from the
// analysed file and may land on an outer parent as the project root.
{
  "stubPath": "typings",
  "include": ["steam", "scripts", "tests"],
  "exclude": ["**/__pycache__", "**/.venv", "vcr", "protobufs", "docs"]
}
